{
  "name": "flaw-kit-vscode",
  "displayName": "FLAW — Flow Logic Audit Watch",
  "description": "Forensic code integrity auditor for AI-generated projects. Finds dead buttons, phantom endpoints, silent failures, and fake flows.",
  "version": "2.1.0",
  "publisher": "AliJakvani",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Testing",
    "Other"
  ],
  "keywords": [
    "ai",
    "code-audit",
    "static-analysis",
    "code-quality",
    "flaw",
    "fail-kit"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/resetroot99/FLAW"
  },
  "homepage": "https://github.com/resetroot99/FLAW",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:python"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flaw.scanFile",
        "title": "FLAW: Scan Current File"
      },
      {
        "command": "flaw.scanWorkspace",
        "title": "FLAW: Scan Workspace"
      },
      {
        "command": "flaw.showReport",
        "title": "FLAW: Show Report"
      },
      {
        "command": "flaw.showScore",
        "title": "FLAW: Show Score"
      },
      {
        "command": "flaw.refreshFindings",
        "title": "FLAW: Refresh Findings",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "flaw.scanFile",
          "group": "flaw"
        }
      ],
      "view/title": [
        {
          "command": "flaw.refreshFindings",
          "when": "view == flawFindings",
          "group": "navigation"
        },
        {
          "command": "flaw.scanWorkspace",
          "when": "view == flawFindings",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "flawFindings",
          "name": "FLAW Findings",
          "icon": "$(shield)",
          "contextualTitle": "FLAW Findings"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "flawFindings",
        "contents": "No FLAW findings yet.\n[Scan Workspace](command:flaw.scanWorkspace)"
      }
    ],
    "configuration": {
      "title": "FLAW",
      "properties": {
        "flaw.enableOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run FLAW analysis on file save"
        },
        "flaw.enableRealTime": {
          "type": "boolean",
          "default": false,
          "description": "Run FLAW analysis on every change (debounced)"
        },
        "flaw.excludePatterns": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/.git/**"
          ],
          "description": "Glob patterns to exclude from analysis"
        },
        "flaw.severityMap": {
          "type": "object",
          "default": {
            "critical": "Error",
            "high": "Error",
            "medium": "Warning",
            "low": "Information",
            "info": "Hint"
          },
          "description": "Map FLAW severity levels to VS Code diagnostic severity"
        },
        "flaw.showInlineAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show inline annotations at end of lines with FLAW findings (Error Lens style)"
        },
        "flaw.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens annotations above functions with FLAW findings"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "build": "node esbuild.config.mjs",
    "build:watch": "node esbuild.config.mjs --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "esbuild": "^0.20.0",
    "@vscode/vsce": "^2.24.0"
  }
}
